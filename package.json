{
  "name": "openclaw-local-memory",
  "version": "3.0.0",
  "description": "Layered local memory system for OpenClaw with project retention, user preferences, auto-reflection, archive compaction, privacy tiers, and dashboard",
  "main": "index.js",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "start": "python3 memory_service.py"
  },
  "keywords": [
    "openclaw",
    "memory",
    "project-memory",
    "preferences",
    "archive",
    "dashboard",
    "agent"
  ],
  "author": "Leon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leon-llb/local-memory.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
